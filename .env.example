# Robco Platform - Environment Variables Example
# Copy this file to .env and fill in your values
# NEVER commit .env with real values to version control

# =============================================================================
# CORE SETTINGS (All Services)
# =============================================================================
APP_ENV=development  # development, staging, production
DATABASE_URL=postgresql://robco:password@localhost:5432/robco_db
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# GATEWAY SERVICE
# =============================================================================
# JWT signing key (min 32 characters for security)
SIGNING_KEY=your-super-secure-signing-key-min-32-characters

# Privacy service configuration
PRIVACY_SERVICE_URL=http://localhost:3010
PRIVACY_SERVICE_TOKEN=your-privacy-service-token

# AI Provider Keys (optional - configure as needed)
OPENAI_API_KEY=sk-your-openai-key
GEMINI_API_KEY=your-gemini-api-key
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MID_TIER_MODEL=gemini-1.5-flash
GEMINI_PREMIUM_MODEL=gemini-1.5-pro

# =============================================================================
# PRIVACY SERVICE
# =============================================================================
SERVICE_TOKEN=your-privacy-service-token
# REDIS_URL already defined above

# =============================================================================
# BIM INGESTION SERVICE
# =============================================================================
# For local MinIO development
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=robco
STORAGE_SECRET_KEY=password123
STORAGE_BUCKET=bim-files

# For Google Cloud Storage (production)
# STORAGE_BACKEND=gcs
# GCS_BUCKET=your-project-bim-storage
# GCS_PROJECT_ID=your-project-id

# =============================================================================
# BILLING SERVICE
# =============================================================================
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# =============================================================================
# ORCHESTRATION SERVICE
# =============================================================================
# Internal service URLs (override for production deployments)
BIM_INGESTION_URL=http://localhost:8001
BILLING_URL=http://localhost:8003
CORE_SERVICE_URL=http://localhost:3000

# =============================================================================
# PRODUCTION NOTES
# =============================================================================
# For staging/production environments:
# 1. Use Secret Manager instead of environment variables
# 2. Set APP_ENV=staging or APP_ENV=production
# 3. Use managed DATABASE_URL from Cloud SQL
# 4. Use managed REDIS_URL from Memorystore
# 5. Generate secure random values for all tokens and keys
# 6. Never use localhost URLs - use Cloud Run service URLs
#
# Example production values (retrieved from Secret Manager):
# DATABASE_URL=postgresql://robco:***@10.0.0.5:5432/robco_db?sslmode=require
# REDIS_URL=redis://:***@10.0.0.6:6379
# SIGNING_KEY=<retrieved-from-secret-manager>
# PRIVACY_SERVICE_URL=https://robco-privacy-***-uc.a.run.app
