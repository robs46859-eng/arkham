APP_ENV=development
DATABASE_URL=postgresql://robco:password@localhost:5432/robco_db
REDIS_URL=redis://localhost:6379/0
ENABLE_PRIVACY_PROXY=true
PRIVACY_RESTORE_RESPONSES=true
PRIVACY_FAIL_CLOSED=false
PRIVACY_SERVICE_URL=http://localhost:3010
PRIVACY_SERVICE_TOKEN=privacy-core-internal-token
PRIVACY_DEFAULT_TIER=dev
PRIVACY_JWT_SECRET=privacy-core-dev-secret
PRIVACY_MASTER_KEY=privacy-core-master-key
