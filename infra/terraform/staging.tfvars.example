project_id               = "your-gcp-project-id"
environment              = "staging"
region                   = "us-central1"
cloud_run_region         = "us-central1"
artifact_registry_name   = "robco-containers"
vpc_name                 = "robco-staging-vpc"

database_name            = "robco_db"
database_user            = "robco"
database_password        = "<SET_VIA_SECRET_MANAGER>"
database_tier            = "db-custom-2-4096"
enable_ha                = false

redis_tier               = "BASIC"
redis_memory_size_gb     = 1
redis_auth_token         = "<SET_VIA_SECRET_MANAGER>"

signing_key              = "<SET_VIA_SECRET_MANAGER>"
admin_token              = "<SET_VIA_SECRET_MANAGER>"
privacy_service_token    = "<SET_VIA_SECRET_MANAGER>"

# Stripe (use test keys for staging)
stripe_secret_key        = "sk_test_..."
stripe_webhook_secret    = "whsec_..."
stripe_price_id          = "price_..."
stripe_success_url       = "https://your-frontend.example.com/billing/success"
stripe_cancel_url        = "https://your-frontend.example.com/billing/cancel"
stripe_portal_return_url = "https://your-frontend.example.com/billing"

stripe_price_plan_map    = "price_your_pro_price=pro,price_your_enterprise_price=enterprise"
stripe_price_entitlement_map = <<EOT
{
  "price_your_omniscale_price": {
    "plan": "pro",
    "verticals": ["omniscale", "papabase"],
    "features": ["premium_escalation", "semantic_cache"],
    "quotas": {
      "max_requests_per_day": 10000
    }
  }
}
EOT

enable_gcs               = true
storage_bucket_name      = "your-staging-storage-bucket"

enable_cloud_run         = true
cloud_run_min_instances  = 0
cloud_run_max_instances  = 5

private_services_access_cidr = "192.168.0.0/24"
