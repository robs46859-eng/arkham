project_id               = "your-gcp-project-id"
environment              = "staging"
region                   = "us-central1"
cloud_run_region         = "us-central1"
artifact_registry_name   = "robco-containers"
vpc_name                 = "robco-staging-vpc"

database_name            = "robco_db"
database_user            = "robco"
database_password        = "replace-with-strong-staging-db-password"
database_tier            = "db-custom-2-4096"
enable_ha                = false

redis_tier               = "BASIC"
redis_memory_size_gb     = 1
redis_auth_token         = "replace-with-strong-staging-redis-token"

signing_key              = "replace-with-32-plus-char-signing-key"
privacy_service_token    = "replace-with-privacy-service-token"

enable_gcs               = true
storage_bucket_name      = "your-staging-storage-bucket"

enable_cloud_run         = true
cloud_run_min_instances  = 0
cloud_run_max_instances  = 5

private_services_access_cidr = "192.168.0.0/24"
